[sub_resource type="Shader" id="Shader_jlvs2"]
code = "shader_type canvas_item;

uniform float height = 50;
uniform float frequency = 1.0;

uniform float speed = 2.0;
void vertex() {
	VERTEX.y += height * sin((frequency * UV.x) + (speed * TIME));
}
"

